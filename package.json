{
  "name": "opendesign-vibe-studio",
  "version": "0.1.0",
  "description": "A local Windows GUI that combines OpenDesign-style design generation with custom endpoint LLM vibe coding.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "start": "electron .",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder --win nsis portable"
  },
  "keywords": [
    "opendesign",
    "vibe-coding",
    "ai-code-generation",
    "openai-compatible",
    "llm",
    "electron",
    "windows",
    "local-first",
    "desktop-app",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/jcrutch-design/opendesign-vibe-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcrutch-design/opendesign-vibe-studio.git"
  },
  "bugs": {
    "url": "https://github.com/jcrutch-design/opendesign-vibe-studio/issues"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.opendesign.vibestudio",
    "productName": "OpenDesign Vibe Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
